{{- $secrets := fromYaml (output "sops" "--decrypt" (joinPath .chezmoi.sourceDir "secrets.sops.yaml")) -}}
#!/usr/bin/env bash
set -euo pipefail

UUID_HOMEOFFICE="{{ index $secrets "disk_uuid_homeoffice" }}"

if [ -e "/dev/disk/by-uuid/$UUID_HOMEOFFICE" ]; then
  PROFILE="homeoffice"
  REPO="local:/mnt/backup-homeoffice/gibson-home"
elif curl -s --max-time 3 -o /dev/null https://{{ index $secrets "nas_domain" }}; then
  PROFILE="nas"
  REPO="{{ index $secrets "nas_restic_repo" }}"
else
  notify-send -u critical "Backup" "No backup target available"
  exit 1
fi

APP_ID="restic-snapshots"

# Toggle: close if already open
if swaymsg -t get_tree | grep -q "restic-snapshots"; then
  swaymsg "[app_id=\"$APP_ID\"] kill"
  exit 0
fi

PASS=$(secret-tool lookup restic gibson-home)

SCRIPT=$(mktemp /tmp/restic-snap.XXXXXX.sh)
cat > "$SCRIPT" << 'OUTER'
#!/usr/bin/env bash
set -euo pipefail
export RESTIC_REPOSITORY="REPO_PLACEHOLDER"
export RESTIC_PASSWORD="PASS_PLACEHOLDER"
PROFILE="PROFILE_PLACEHOLDER"

printf "\n  \033[1m󰪩 Live Backup Check — %s\033[0m\n" "$PROFILE"
printf "  %s\n\n" "$(printf '─%.0s' {1..40})"

printf "  \033[1mRestic Snapshots\033[0m\n\n"
restic snapshots --compact --latest 5 2>/dev/null | sed 's/^/  /'

printf "\n  %s\n\n" "$(printf '─%.0s' {1..40})"
printf "  \033[1mBtrfs Snapshots\033[0m\n\n"
printf "  Root:\n"
snapper -c root list --columns number,date,type | tail -n 3 | sed 's/^/  /'
printf "\n  Home:\n"
snapper -c home list --columns number,date,type | tail -n 3 | sed 's/^/  /'

printf "\n  %s\n" "$(printf '─%.0s' {1..40})"
printf "  Press any key to close\n"
read -n 1 -s -r
OUTER

sed -i "s|REPO_PLACEHOLDER|$REPO|;s|PASS_PLACEHOLDER|$PASS|;s|PROFILE_PLACEHOLDER|$PROFILE|" "$SCRIPT"
chmod +x "$SCRIPT"

foot --app-id "$APP_ID" -W 100x35 bash "$SCRIPT" &
disown
