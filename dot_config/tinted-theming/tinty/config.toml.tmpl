# Global settings
shell = "zsh -c '{}'"
default-scheme = "base16-darktooth"

[[items]]
name = "tinted-shell"
path = "https://github.com/tinted-theming/tinted-shell"
themes-dir = "scripts"
hook = "source %f"

[[items]]
path = "https://github.com/tinted-theming/tinted-fzf"
name = "tinted-fzf"
themes-dir = "sh"
hook = "source %f"

[[items]]
path = "https://github.com/tinted-theming/tinted-terminal"
name = "tinted-terminal-wezterm"
themes-dir = "themes/wezterm"
hook = "cp -f %f ~/.config/wezterm/colors/tinted-theming.toml"
supported-systems = ["base16", "base24"]

{{- if eq .chezmoi.os "linux" }} {{- if eq (printf "%.4s" .chezmoi.osRelease.id) "arch" }}

[[items]]
name = "base16-sway"
path = "https://github.com/rkubosz/base16-sway"
themes-dir = "themes"
revision = "master"
hook = "cp -f %f ~/.config/sway/base16.config && swaymsg reload && sleep 0.5 && ~/.config/waybar/scripts/waybar-reload.sh"

[[items]]
path = "https://github.com/tinted-theming/base16-waybar"
name = "base16-waybar"
themes-dir = "colors"
hook = "cp -f %f ~/.config/waybar/colors.css && killall -SIGUSR2 waybar"

[[items]]
path = "https://github.com/tinted-theming/base16-waybar"
name = "base16-rofi-sync"
themes-dir = "colors"
hook = "~/.config/rofi/generate-colors.sh"

[[items]]
path = "https://github.com/tinted-theming/base16-waybar"
name = "base16-wob-sync"
themes-dir = "colors"
hook = "~/.config/wob/generate-colors.sh"

# Swaync uses waybar colors - just run the sync script
[[items]]
name = "base16-swaync-sync"
path = "https://github.com/tinted-theming/base16-waybar"
themes-dir = "colors"
hook = "~/.config/swaync/generate-colors.sh && swaync-client --reload-css"

[[items]]
path = "https://git.sr.ht/~blueingreen/base16-btop"
name = "base16-btop"
themes-dir = "colors"
hook = "cp -f %f ~/.config/btop/themes/colors.theme && killall -SIGUSR2 btop 2>/dev/null || true"

[[items]]
path = "https://github.com/tinted-theming/base16-waybar"
name = "base16-obsidian-sync"
themes-dir = "colors"
hook = "~/.config/obsidian/generate-colors.sh"

{{- end }} {{- end }}

{{- if eq .chezmoi.os "darwin" }}

[[items]]
path = "https://github.com/tinted-theming/base16-iterm2"
name = "base16-iterm2"
themes-dir = "itermcolors-256"
hook = "cp -f %f ~/.config/iterm2/tinty-managed.itermcolors && ~/.config/iterm2/apply-tinty-theme.sh"

{{- end }}
