# XDG Base Directory
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# History
HISTFILE="$XDG_DATA_HOME/zsh/history"
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt SHARE_HISTORY

# Completion system (must be before antidote)
autoload -Uz compinit
compinit -C -d "$XDG_CACHE_HOME/zsh/zcompdump-$ZSH_VERSION"

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
setopt COMPLETE_IN_WORD

# Starship prompt (must be before transient-prompt plugin)
if [[ "$TERM" == "linux" ]]; then
  export STARSHIP_CONFIG=~/.config/starship/starship-linux.toml
else
  export STARSHIP_CONFIG=~/.config/starship/starship.toml
fi
eval "$(starship init zsh)"
TRANSIENT_PROMPT_TRANSIENT_PROMPT='$(starship prompt --profile transient)'

# Antidote plugin manager
export ANTIDOTE_HOME="$XDG_DATA_HOME/antidote"
source "$XDG_DATA_HOME/antidote-src/antidote.zsh"
antidote load "$XDG_CONFIG_HOME/zsh/.zsh_plugins.txt"

# OSC 133 semantic prompt markers + OSC 7 cwd reporting (foot uses these natively)
# Also write cwd to file for foot-spawn.sh to inherit on Mod+Return
if [[ "$TERM" == foot* || -n "$WEZTERM_EXECUTABLE" ]]; then
  _osc_prompt_start() { printf '\e]133;A\e\\'; }
  _osc_command_start() { printf '\e]133;C\e\\'; }
  _osc7_cwd() { printf '\e]7;file://%s%s\e\\' "$HOST" "$PWD"; }
  _osc_title_precmd() { printf '\e]0;%s\e\\' "${PWD/#$HOME/~}"; }
  _osc_title_preexec() { printf '\e]0;%s — %s\e\\' "${PWD/#$HOME/~}" "$1"; }
  if [[ -d "$XDG_RUNTIME_DIR" ]]; then
    _foot_track_cwd() { echo "$PWD" > "$XDG_RUNTIME_DIR/foot-last-cwd"; }
    precmd_functions+=(_osc_prompt_start _osc7_cwd _osc_title_precmd _foot_track_cwd)
  else
    precmd_functions+=(_osc_prompt_start _osc7_cwd _osc_title_precmd)
  fi
  preexec_functions+=(_osc_command_start _osc_title_preexec)
fi

{{- if eq .chezmoi.os "darwin" }}
# Simulate systemd environment.d on macOS
for conf in "$XDG_CONFIG_HOME/environment.d/"*.conf; do
  set -a; source "$conf"; set +a
done
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
# GPG agent needs TTY for pinentry (SSH auth, signing)
export GPG_TTY=$(tty)
gpg-connect-agent updatestartuptty /bye >/dev/null 2>&1
{{- end }}

# Vi key bindings
bindkey -v
autoload -Uz edit-command-line
zle -N edit-command-line
bindkey -M vicmd 'vv' edit-command-line

# Editor aliases
if command -v vim &> /dev/null; then
  alias vi=vim
fi

if command -v nvim &> /dev/null; then
  alias vi=nvim
  export MANPAGER='nvim +Man!'
fi

# Common aliases
{{- if eq .chezmoi.os "linux" }}
alias o='xdg-open'
{{- else }}
alias o='open'
{{- end }}
alias cm='chezmoi'

# Yazi with cwd sync
function f() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

if command -v eza &> /dev/null; then
  alias ls='eza --icons'
  alias ll='eza --icons -l'
  alias la='eza --icons -la'
  alias lt='eza --icons --tree --level=3'
fi

if command -v btop &> /dev/null; then
  alias top='btop'
fi

# Git aliases
alias g='git'
alias ga='git add'
alias gaa='git add --all'
alias gd='git diff'
alias gp='git push'
alias gst='git status'
alias glog='git log --oneline --decorate --graph'

# Docker aliases
alias dps='docker ps'
alias dex='docker exec -it'
alias dlog='docker logs -f'

{{- if eq .chezmoi.os "linux" }}
# Systemd aliases
alias sc='systemctl'
alias scu='systemctl --user'
alias scs='systemctl status'
alias scr='systemctl restart'
{{- end }}

{{- if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "arch") }}
# Pacman aliases
alias pacupg='sudo pacman -Syu'
alias pacin='sudo pacman -S'
alias pacreps='pacman -Ss'
alias pacrem='sudo pacman -Rns'

# Yay wrapper: refresh waybar updates counter after install/upgrade
yay() {
  command yay "$@" && pkill -RTMIN+8 waybar 2>/dev/null
}

source /usr/share/doc/pkgfile/command-not-found.zsh
{{- end }}

if command -v neomutt &> /dev/null; then
  alias neomutt="TERM=screen-256color neomutt"
  alias mutt="TERM=screen-256color neomutt"
fi

{{- if eq .chezmoi.os "darwin" }}
# macOS specific
alias tinty='tinty --config=~/.config/tinted-theming/tinty/config.toml --data-dir=~/.local/share/tinted-theming/tinty'

# Homebrew command-not-found
HOMEBREW_COMMAND_NOT_FOUND_HANDLER="$(brew --repository)/Library/Homebrew/command-not-found/handler.sh"
if [ -f "$HOMEBREW_COMMAND_NOT_FOUND_HANDLER" ]; then
  source "$HOMEBREW_COMMAND_NOT_FOUND_HANDLER"
fi
{{- end }}

# Tool integrations
eval "$(mise activate zsh)"
eval "$(zoxide init zsh)"

# fzf integration
{{- if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "arch") }}
source /usr/share/fzf/key-bindings.zsh
source /usr/share/fzf/completion.zsh
{{- end }}
{{- if eq .chezmoi.os "darwin" }}
source $(brew --prefix)/opt/fzf/shell/key-bindings.zsh
source $(brew --prefix)/opt/fzf/shell/completion.zsh
{{- end }}

# LESS
LESSOPEN="|lesspipe.sh %s"; export LESSOPEN

# Theming
if command -v tinty &>/dev/null && tinty current &>/dev/null; then
  source "$(tinty config --data-dir-path)/repos/tinted-fzf/sh/$(tinty current).sh"
fi

# Native completions
command -v kubectl &>/dev/null && source <(kubectl completion zsh)
command -v gh &>/dev/null && eval "$(gh completion -s zsh)"

# Bash-style completions (terraform, aws)
autoload -U +X bashcompinit && bashcompinit
command -v terraform &>/dev/null && complete -o nospace -C terraform terraform
command -v aws_completer &>/dev/null && complete -C aws_completer aws

# Go
go env -w GOPATH=$HOME/.local/share/go
export GOTESTS_TEMPLATE=testify

{{- if eq .chezmoi.os "darwin" }}
[[ "$TERM_PROGRAM" == "kiro" ]] && . "$(kiro --locate-shell-integration-path zsh)"
{{- end }}

# Aliases
alias ll='ls -l'
alias la='ls -la'
alias -g G='| grep'
alias -g L='| less'
