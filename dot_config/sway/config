include ./base16.config

# Colors
client.focused          $base05 $base03 $base06 $base03 $base05
client.focused_inactive $base01 $base01 $base05 $base03 $base01
client.unfocused        $base01 $base00 $base05 $base01 $base01
client.urgent           $base08 $base08 $base00 $base08 $base08
client.placeholder      $base00 $base00 $base05 $base00 $base00
client.background       $base07

font pango: Roboto 11
titlebar_padding 6 1

# Variables
set $terminal wezterm
set $mod Mod4
set $background-image ~/.config/sway/resources/background.jpg
set $lock "swaylock -k -l -F -f --image $background-image"

# Input
input type:touchpad {
    tap enabled
    natural_scroll enabled
}

input * {
    xkb_layout "us(altgr-intl)"
}

# Output
output eDP-1 scale 1.5
output * bg $background-image fill

floating_modifier $mod

# Terminal
bindsym $mod+Return exec $terminal

# Kill focused window
bindsym $mod+Shift+q kill

# Focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+Control+Right focus output right
bindsym $mod+Control+Left focus output left
bindsym $mod+a focus parent

# Move window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Layout
bindsym $mod+n split h
bindsym $mod+u split v
bindsym $mod+f fullscreen toggle
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+Ctrl+space focus mode_toggle

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"

bindsym $mod+1 workspace number $ws1; move workspace to output current
bindsym $mod+2 workspace number $ws2; move workspace to output current
bindsym $mod+3 workspace number $ws3; move workspace to output current
bindsym $mod+4 workspace number $ws4; move workspace to output current
bindsym $mod+5 workspace number $ws5; move workspace to output current
bindsym $mod+6 workspace number $ws6; move workspace to output current
bindsym $mod+7 workspace number $ws7; move workspace to output current
bindsym $mod+8 workspace number $ws8; move workspace to output current
bindsym $mod+9 workspace number $ws9; move workspace to output current

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9

bindgesture swipe:right workspace prev
bindgesture swipe:left workspace next

# Resize mode
mode "resize" {
    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt
    bindsym Left resize shrink width 10 px or 10 ppt
    bindsym Down resize grow height 10 px or 10 ppt
    bindsym Up resize shrink height 10 px or 10 ppt
    bindsym Right resize grow width 10 px or 10 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# System
bindsym $mod+Shift+c exec "pkill waybar; swaymsg reload"
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "swaynag -t warning -m 'Do you really want to exit sway?' -B 'Yes, exit sway' 'swaymsg exit'"
bindsym $mod+Shift+Escape exec $lock

# KiCad
for_window [title=".* — PCB Editor"] resize set width 80 ppt
for_window [title=".* — Schematic Editor"] resize set width 80 ppt

bar {
    swaybar_command waybar
}

include ./config.d/*
