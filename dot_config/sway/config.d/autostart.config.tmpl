# Autostart applications
{{ if eq .chezmoi.hostname "fender" -}}
exec swayidle -w \
    timeout 600 $lock \
    before-sleep $lock
{{ else -}}
exec swayidle -w \
    timeout 600 $lock \
    timeout 300 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' before-sleep $lock
{{ end -}}
exec ~/.config/sway/bin/output-flash.sh
exec ~/.config/waybar/scripts/waybar-reload.sh

exec "gdbus wait --session org.freedesktop.Notifications && firefox"
exec $terminal --app-id=main-terminal
exec keepassxc ~/data/pw/pw.kdbx

# Workspace assignments
assign [app_id="firefox"] $ws1
assign [app_id="main-terminal"] $ws2
assign [app_id="obsidian"] $ws3
