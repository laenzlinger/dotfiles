# Sway Window Manager Shortcuts
# Mod = Super/Windows key

## Applications
# Launch terminal
Mod+Enter

# Launch app launcher (rofi, toggle)
Mod+Space

# Window switcher (rofi, toggle)
Mod+Tab

# File search (rofi, toggle)
Mod+Shift+f

# Toggle KeePassXC
Mod+Shift+s

# Network switcher (rofi, toggle)
Mod+Shift+w

# Toggle Blueman
Mod+Shift+b

# Toggle Helvum audio patchbay
Mod+Shift+a

# Toggle Microscope
Mod+Shift+m

# Toggle Notifications
Mod+Shift+n

# USB unmount (rofi)
Mod+Shift+u

# Cheatsheet browser
Mod+Shift+/ (Mod+?)

# Calculator (rofi, result copied to clipboard)
Mod+=
# In calculator: type expression, Enter to copy result
# Examples: 2^16, sqrt(144), 30% of 250, 5 miles to km
# Clear history: rm ~/.local/share/rofi/rofi_calc_history

## Clipboard (rofi)
# Pick from clipboard history
Mod+v

# Clear clipboard history
Mod+c

## Window Management
# Kill focused window
Mod+Shift+q

# Toggle fullscreen
Mod+f

# Toggle floating
Mod+Shift+Space

# Focus floating/tiling
Mod+Ctrl+Space

## Focus
# Focus left/down/up/right (vim keys)
Mod+h/j/k/l

# Focus left/down/up/right (arrows)
Mod+Left/Down/Up/Right

# Focus parent container
Mod+a

# Focus output (monitor)
Mod+Ctrl+Left/Right

## Move Windows
# Move window (vim keys)
Mod+Shift+h/j/k/l

# Move window (arrows)
Mod+Shift+Left/Down/Up/Right

## Layout
# Split horizontal
Mod+n

# Split vertical
Mod+u

# Stacking layout
Mod+s

# Tabbed layout
Mod+w

# Toggle split layout
Mod+e

## Workspaces
# Switch to workspace 1-9, 0
Mod+1-9, Mod+0

# Move window to workspace 1-9, 0
Mod+Shift+1-9, Mod+Shift+0

# 1-7 external, 8-9-0 laptop (single monitor: all on one screen)
(dual monitor)

# Swipe between workspaces
Swipe left/right (touchpad)

## Resize Mode
# Enter resize mode
Mod+r

# In resize mode: h/j/k/l or arrows to resize
# Exit: Enter/Escape/Mod+r

## System
# Reload Sway config
Mod+Shift+c

# Restart Sway
Mod+Shift+r

# Power menu (rofi: lock/logout/suspend/reboot/shutdown)
Mod+Shift+e

# Lock screen
Mod+Shift+Escape

## Screenshots
# Screenshot area to clipboard
Print

# Screenshot area to file
Shift+Print

# Full screen to clipboard
Ctrl+Print

# Full screen to file
Ctrl+Shift+Print

## Media Keys
# Volume up/down
XF86AudioRaiseVolume/LowerVolume

# Mute audio
XF86AudioMute

# Mute microphone
XF86AudioMicMute

# Brightness up/down
XF86MonBrightnessUp/Down

# Connect VPN (Netbird)
Phone Pickup key

# Disconnect VPN
Phone Hangup key
