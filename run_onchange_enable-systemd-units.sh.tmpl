{{- if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
set -euo pipefail

# Enable user systemd units managed by this dotfiles repo
# Re-runs whenever this file or unit files change (chezmoi run_onchange_)
#
# Services:
#   darkman              - Dark/light mode switcher
#   syncthing            - File synchronization
#   udiskie              - USB automounter
#   polkit-gnome         - PolicyKit authentication agent (privilege escalation dialogs)
#   systembus-notify     - Forward system D-Bus notifications to desktop
#   shikane              - Wayland output/display configuration manager
#   btrfs-desktop-notification - Btrfs filesystem health notifications
#   blueman-applet       - Bluetooth system tray applet
#   swaync               - Sway notification center
#   clipboard-watcher    - Clipboard manager watcher (wl-paste)
#   wob                  - Wayland overlay bar (volume/brightness indicators)
#   secret-monitor       - Notifies which process requests secrets from KeePassXC
#
# Note: Only runs on Linux. Unit files are in ~/.config/systemd/user/

units=(
  darkman.service
  syncthing.service
  udiskie.service
  polkit-gnome.service
  systembus-notify.service
  shikane.service
  btrfs-desktop-notification.service
  blueman-applet.service
  swaync.service
  clipboard-watcher.service
  secret-monitor.service
  wob.socket
  wob.service
)

for unit in "${units[@]}"; do
  if ! systemctl --user is-enabled "$unit" &>/dev/null; then
    echo "Enabling $unit"
    systemctl --user enable --now "$unit"
  fi
done
{{- end -}}
